.detail-page {
  padding-bottom: 48rpx;
}

.detail-header,
.fee-panel,
.section {
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.detail-header {
  padding: 28rpx;
}

.detail-title,
.detail-address {
  display: block;
}

.detail-title {
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.2;
}

.detail-address {
  margin-top: 14rpx;
  color: #657286;
  font-size: 26rpx;
  line-height: 1.5;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.source-panel {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf1f4;
}

.owner-row,
.section-heading-row,
.vote-row {
  display: flex;
  align-items: center;
}

.owner-row {
  gap: 16rpx;
}

.owner-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  overflow: hidden;
  border-radius: 50%;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.owner-avatar-image {
  width: 100%;
  height: 100%;
}

.owner-info {
  flex: 1;
  min-width: 0;
}

.owner-label,
.owner-name {
  display: block;
}

.owner-label {
  color: #657286;
  font-size: 22rpx;
}

.owner-name {
  margin-top: 6rpx;
  color: #18212f;
  font-size: 28rpx;
  font-weight: 800;
}

.edit-button {
  flex: 0 0 128rpx;
  min-height: 60rpx;
  font-size: 24rpx;
}

.fee-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 20rpx;
  padding: 28rpx;
}

.panel-label {
  display: block;
  color: #657286;
  font-size: 24rpx;
}

.fee-value {
  display: block;
  margin-top: 10rpx;
  color: #c25b22;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}

.nav-button {
  flex: 0 0 180rpx;
}

.section {
  margin-top: 20rpx;
  padding: 26rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 800;
}

.section-heading-row {
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.section-heading-row .section-title {
  margin-bottom: 0;
}

.confidence-value {
  color: #166a5b;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.body-text,
.body-hint {
  display: block;
  font-size: 28rpx;
  line-height: 1.55;
}

.body-text {
  color: #2c3e50;
}

.body-hint {
  margin-top: 10rpx;
  color: #657286;
}

.vote-row {
  gap: 14rpx;
  margin-top: 20rpx;
}

.vote-button {
  flex: 1;
  min-width: 0;
  min-height: 70rpx;
  padding: 0 14rpx;
  font-size: 25rpx;
}

.vote-button.is-active {
  color: #ffffff;
  background: #166a5b;
}

.data-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #edf1f4;
}

.data-row:first-of-type {
  border-top: 0;
}

.data-label {
  flex: 0 0 150rpx;
  color: #657286;
  font-size: 26rpx;
}

.data-value {
  flex: 1;
  color: #18212f;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: right;
  word-break: break-all;
}

.bottom-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.photo-thumb {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 6rpx;
  background: #eef3f6;
}
