.index-page {
  position: relative;
  height: 100vh;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: #eef3f6;
}

.map-background {
  position: absolute;
  top: 0;
  right: 0;
  bottom: auto;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.map-top-tools {
  position: absolute;
  top: 18rpx;
  top: calc(env(safe-area-inset-top) + 18rpx);
  left: 28rpx;
  right: 28rpx;
  z-index: 4;
}

.search-shell {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dde4ec;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 32rpx rgba(24, 33, 47, 0.12);
}

.search-prefix {
  flex: 0 0 44rpx;
  color: #667485;
  font-size: 26rpx;
  font-weight: 800;
}

.map-search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #18212f;
  font-size: 30rpx;
}

.map-more-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  color: #657286;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.top-action-row {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 14rpx;
}

.account-chip,
.add-button {
  box-shadow: 0 8rpx 24rpx rgba(24, 33, 47, 0.1);
}

.account-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 192rpx;
  min-height: 56rpx;
  padding: 0 12rpx;
  border: 1rpx solid #d8e3ea;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
}

.account-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #9aa6b2;
}

.account-chip.is-authenticated .account-dot {
  background: #166a5b;
}

.account-status,
.account-action {
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.account-status {
  color: #243244;
  font-weight: 700;
}

.account-action {
  color: #657286;
}

.add-button {
  width: 192rpx;
  flex: 0 0 auto;
  min-width: 0;
  min-height: 56rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.96);
}

.map-action-stack {
  position: absolute;
  right: 32rpx;
  z-index: 4;
}

.map-round-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border: 0;
  border-radius: 28rpx;
  background: rgba(248, 252, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(20, 47, 66, 0.2);
}

.locate-control {
  position: relative;
  overflow: hidden;
}

.locate-control::before {
  content: "";
  position: absolute;
  top: 8rpx;
  left: 10rpx;
  width: 48rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.66);
}

.locate-control::after {
  content: "";
  position: absolute;
  right: 10rpx;
  bottom: 8rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(36, 184, 211, 0.2);
  box-shadow: 0 0 26rpx rgba(36, 184, 211, 0.35);
}

.locate-control-hover {
  transform: scale(0.96);
  opacity: 0.92;
}

.locate-orb {
  position: relative;
  z-index: 1;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #eefbff 0%, #d9f6ff 46%, #ffffff 100%);
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.82),
    inset 0 -8rpx 18rpx rgba(33, 151, 191, 0.16),
    0 0 24rpx rgba(33, 151, 191, 0.26);
}

.locate-ring,
.locate-axis,
.locate-arrow,
.locate-dot {
  position: absolute;
}

.locate-ring {
  border-radius: 50%;
  border-style: solid;
}

.locate-ring-outer {
  top: 6rpx;
  right: 6rpx;
  bottom: 6rpx;
  left: 6rpx;
  border-width: 2rpx;
  border-color: rgba(24, 128, 172, 0.42);
}

.locate-ring-inner {
  top: 17rpx;
  right: 17rpx;
  bottom: 17rpx;
  left: 17rpx;
  border-width: 2rpx;
  border-color: rgba(22, 106, 91, 0.36);
}

.locate-axis {
  left: 50%;
  top: 50%;
  background: rgba(16, 92, 118, 0.42);
  transform: translate(-50%, -50%);
}

.locate-axis-x {
  width: 40rpx;
  height: 2rpx;
}

.locate-axis-y {
  width: 2rpx;
  height: 40rpx;
}

.locate-arrow {
  left: 25rpx;
  top: 12rpx;
  width: 0;
  height: 0;
  border-left: 9rpx solid transparent;
  border-right: 9rpx solid transparent;
  border-bottom: 28rpx solid #176fd4;
  transform: rotate(42deg);
  transform-origin: 50% 76%;
}

.locate-arrow::after {
  content: "";
  position: absolute;
  left: -4rpx;
  top: 11rpx;
  width: 8rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #f8fcff;
}

.locate-dot {
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #20cad3;
  box-shadow: 0 0 14rpx rgba(32, 202, 211, 0.78);
  transform: translate(-50%, -50%);
}

.bottom-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  display: flex;
  flex-direction: column;
  min-height: 328px;
  border-radius: 28rpx 28rpx 0 0;
  background: linear-gradient(180deg, rgba(219, 243, 253, 0.96) 0%, #f7fbff 42%, #ffffff 100%);
  box-shadow: 0 -18rpx 48rpx rgba(25, 80, 120, 0.18);
  overflow: hidden;
}

.bottom-sheet.is-animating {
  transition: height 220ms ease, transform 220ms ease;
}

.sheet-plan-card {
  flex: 0 0 auto;
  padding: 14rpx 28rpx 22rpx;
}

.sheet-drag-zone {
  padding-top: 4rpx;
}

.sheet-grabber {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  background: rgba(52, 80, 107, 0.26);
}

.sheet-summary-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 28rpx rgba(25, 80, 120, 0.08);
}

.sheet-summary-main {
  flex: 1;
  min-width: 0;
}

.sheet-title-line,
.control-header,
.list-header,
.lot-main,
.metric-row,
.action-row,
.search-results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sheet-title-line {
  align-items: baseline;
}

.sheet-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.sheet-caret {
  flex: 0 0 auto;
  color: #7a8796;
  font-size: 22rpx;
  font-weight: 700;
}

.sheet-summary {
  display: block;
  margin-top: 10rpx;
  color: #6f7c8d;
  font-size: 24rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.sheet-count-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 0 0 120rpx;
  min-height: 96rpx;
  border-radius: 8rpx;
  color: #2f7fed;
  background: #edf5ff;
}

.sheet-count-number {
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.sheet-count-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.quick-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.quick-summary-item,
.quick-control {
  min-width: 0;
  padding: 16rpx 14rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
}

.quick-label,
.quick-value {
  display: block;
}

.quick-label {
  color: #657286;
  font-size: 22rpx;
}

.quick-value {
  margin-top: 8rpx;
  color: #18212f;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mode-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
}

.mode-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 8rpx;
  color: #344456;
  font-size: 30rpx;
  font-weight: 800;
}

.mode-tab.is-active {
  color: #ffffff;
  background: #2f7fed;
  box-shadow: 0 8rpx 20rpx rgba(47, 127, 237, 0.22);
}

.list-mode-tabs {
  margin: 0 0 18rpx;
  background: #ffffff;
}

.sheet-scroll {
  flex: 1;
  min-height: 0;
}

.sheet-content {
  padding: 0 28rpx 36rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 36rpx);
}

.expanded-controls {
  padding-bottom: 22rpx;
}

.map-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #d9e7e3;
  border-radius: 8rpx;
  background: #f2f8f6;
}

.map-meta-main {
  flex: 1;
  min-width: 0;
}

.location-status-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #166a5b;
}

.status-dot.is-locating {
  background: #c25b22;
}

.location-status-text {
  color: #4c6072;
  font-size: 22rpx;
  font-weight: 700;
}

.destination-name,
.destination-address {
  display: block;
}

.destination-name {
  color: #143d35;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.destination-address {
  margin-top: 8rpx;
  color: #5d6f7d;
  font-size: 24rpx;
  line-height: 1.4;
}

.quick-controls {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.expanded-quick-controls {
  margin-top: 18rpx;
}

.primary-control {
  border-color: #cddfeb;
  background: #ffffff;
}

.main-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.main-action-button {
  width: 100%;
  min-width: 0;
  min-height: 76rpx;
}

.duration-panel {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-title {
  color: #18212f;
  font-size: 30rpx;
  font-weight: 800;
}

.duration-value {
  color: #166a5b;
  font-size: 36rpx;
  font-weight: 800;
}

.duration-hint {
  display: block;
  margin-top: 8rpx;
  color: #7a8796;
  font-size: 22rpx;
}

.duration-picker-shell {
  position: relative;
  margin-top: 18rpx;
  overflow: hidden;
  border: 1rpx solid #d9e2ea;
  border-radius: 8rpx;
  background: #f8fafc;
}

.duration-picker-shell::before,
.duration-picker-shell::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  z-index: 1;
  height: 84rpx;
  pointer-events: none;
}

.duration-picker-shell::before {
  top: 0;
  background: linear-gradient(180deg, #f8fafc 0%, rgba(248, 250, 252, 0) 100%);
}

.duration-picker-shell::after {
  bottom: 0;
  background: linear-gradient(0deg, #f8fafc 0%, rgba(248, 250, 252, 0) 100%);
}

.duration-picker {
  width: 100%;
  height: 288rpx;
}

.duration-picker-indicator {
  border-top: 1rpx solid #dce4ec;
  border-bottom: 1rpx solid #dce4ec;
  background: rgba(255, 255, 255, 0.72);
}

.duration-picker-mask {
  background: transparent;
}

.duration-wheel-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  color: #8a97a6;
  line-height: 1;
}

.duration-wheel-number {
  min-width: 42rpx;
  color: #18212f;
  font-size: 34rpx;
  font-weight: 800;
  text-align: right;
}

.duration-wheel-unit {
  margin-left: 6rpx;
  color: #58677a;
  font-size: 24rpx;
  font-weight: 700;
}

.custom-panel {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #e7edf2;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 28rpx;
  width: 100%;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d9e2ea;
  border-radius: 6rpx;
  background: #f8fafc;
  color: #18212f;
  font-size: 28rpx;
}

.clear-button {
  flex: 0 0 104rpx;
  width: 104rpx;
  min-height: 76rpx;
  padding: 0;
  font-size: 26rpx;
}

.choose-button {
  flex: 0 0 154rpx;
  width: 154rpx;
  min-height: 76rpx;
  padding: 0;
  font-size: 24rpx;
  white-space: nowrap;
}

.match-panel,
.search-results-panel {
  margin: -12rpx 0 28rpx;
  padding: 18rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.match-title {
  display: block;
  color: #435268;
  font-size: 24rpx;
  font-weight: 800;
}

.match-row,
.parking-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #eef2f5;
}

.match-row:first-of-type,
.parking-result:first-of-type {
  border-top: 0;
}

.match-info,
.parking-result-main {
  flex: 1;
  min-width: 0;
}

.match-name,
.match-address {
  display: block;
}

.match-name {
  color: #18212f;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.match-address {
  margin-top: 6rpx;
  color: #738196;
  font-size: 23rpx;
  line-height: 1.35;
}

.match-action {
  flex: 0 0 132rpx;
  color: #166a5b;
  font-size: 24rpx;
  font-weight: 800;
  text-align: right;
}

.parking-result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
  color: #3e5065;
  font-size: 23rpx;
}

.parking-result-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  flex: 0 0 112rpx;
  color: #166a5b;
  font-size: 23rpx;
  font-weight: 800;
  text-align: right;
}

.list-header {
  margin: 4rpx 0 18rpx;
}

.lot-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.lot-card.is-best {
  border-color: #8dbcf8;
  box-shadow: 0 10rpx 30rpx rgba(47, 127, 237, 0.12);
}

.lot-main {
  align-items: flex-start;
}

.rank-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #1f2937;
  font-size: 26rpx;
  font-weight: 800;
}

.lot-info {
  flex: 1;
  min-width: 0;
}

.lot-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.lot-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.type-label,
.best-label {
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.type-label.is-street {
  color: #ffffff;
  background: #2f7fed;
}

.type-label.is-offstreet {
  color: #ffffff;
  background: #166a5b;
}

.best-label {
  color: #ffffff;
  background: #c25b22;
}

.lot-address {
  display: block;
  margin-top: 8rpx;
  color: #657286;
  font-size: 24rpx;
  line-height: 1.4;
}

.price-box {
  flex: 0 0 128rpx;
  text-align: right;
}

.price,
.price-note {
  display: block;
}

.price {
  color: #c25b22;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.price-note {
  margin-top: 8rpx;
  color: #657286;
  font-size: 22rpx;
}

.metric-row {
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 20rpx;
  color: #3e5065;
  font-size: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.reason {
  display: block;
  margin-top: 18rpx;
  color: #2c3e50;
  font-size: 26rpx;
  line-height: 1.5;
}

.source-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.source-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  overflow: hidden;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.source-avatar-image {
  width: 100%;
  height: 100%;
}

.source-name,
.source-confidence {
  color: #657286;
  font-size: 22rpx;
  line-height: 1.35;
}

.source-name {
  color: #344456;
  font-weight: 700;
}

.action-row {
  margin-top: 22rpx;
}

.action-button {
  flex: 1;
}

.sheet-empty {
  margin-top: 8rpx;
}
