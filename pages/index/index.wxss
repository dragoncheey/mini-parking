.index-page {
  position: relative;
  height: 100vh;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: #eef3f6;
}

.map-background {
  position: absolute;
  top: 0;
  right: 0;
  bottom: auto;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.map-search-bar,
.map-top-actions {
  position: absolute;
  top: 18rpx;
  top: calc(env(safe-area-inset-top) + 18rpx);
  left: 28rpx;
  right: 28rpx;
  z-index: 4;
}

.map-search-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.map-back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 88rpx;
  color: #111827;
  font-size: 64rpx;
  font-weight: 500;
  line-height: 1;
}

.search-shell {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  padding: 0 20rpx;
  border: 3rpx solid #111827;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 28rpx rgba(24, 33, 47, 0.12);
}

.search-prefix {
  flex: 0 0 44rpx;
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.map-search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #18212f;
  font-size: 30rpx;
}

.map-more-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.map-top-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  pointer-events: none;
}

.map-account-chip,
.map-add-action {
  pointer-events: auto;
  box-shadow: 0 10rpx 26rpx rgba(24, 33, 47, 0.14);
}

.map-account-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  max-width: 188rpx;
  min-height: 60rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8e3ea;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(12rpx);
}

.account-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #9aa6b2;
}

.map-account-chip.is-authenticated .account-dot {
  background: #166a5b;
}

.account-status,
.account-action {
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.account-status {
  color: #243244;
  font-weight: 700;
}

.account-action {
  color: #657286;
}

.map-add-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 60rpx;
  width: 60rpx;
  min-width: 0;
  height: 60rpx;
  padding: 0;
  border-radius: 50%;
  color: #111827;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(12rpx);
}

.map-add-plus {
  color: #111827;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}

.map-action-stack {
  position: absolute;
  right: 32rpx;
  z-index: 4;
  display: grid;
  gap: 18rpx;
}

.map-round-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(12rpx);
  box-shadow: 0 10rpx 26rpx rgba(24, 33, 47, 0.14);
}

.expand-map-control,
.locate-control {
  position: relative;
}

.locate-control-hover,
.expand-map-control-hover {
  transform: scale(0.96);
  opacity: 0.92;
}

.map-mini-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
}

.mini-corner,
.mini-axis,
.mini-ring,
.mini-dot {
  position: absolute;
}

.mini-corner {
  width: 12rpx;
  height: 12rpx;
  border-color: #111827;
  border-style: solid;
}

.mini-corner-tl {
  top: 3rpx;
  left: 3rpx;
  border-width: 3rpx 0 0 3rpx;
}

.mini-corner-tr {
  top: 3rpx;
  right: 3rpx;
  border-width: 3rpx 3rpx 0 0;
}

.mini-corner-bl {
  bottom: 3rpx;
  left: 3rpx;
  border-width: 0 0 3rpx 3rpx;
}

.mini-corner-br {
  right: 3rpx;
  bottom: 3rpx;
  border-width: 0 3rpx 3rpx 0;
}

.mini-axis {
  left: 50%;
  top: 50%;
  background: #111827;
  transform: translate(-50%, -50%);
}

.mini-axis-x {
  width: 28rpx;
  height: 3rpx;
}

.mini-axis-y {
  width: 3rpx;
  height: 28rpx;
}

.mini-ring {
  top: 7rpx;
  right: 7rpx;
  bottom: 7rpx;
  left: 7rpx;
  border: 3rpx solid #111827;
  border-radius: 50%;
}

.mini-dot {
  left: 50%;
  top: 50%;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #111827;
  transform: translate(-50%, -50%);
}

.bottom-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  display: flex;
  flex-direction: column;
  min-height: 220px;
  border-radius: 28rpx 28rpx 0 0;
  background: #f2f5f8;
  box-shadow: 0 -18rpx 48rpx rgba(25, 80, 120, 0.18);
  overflow: hidden;
}

.bottom-sheet.is-animating {
  transition: height 220ms ease, transform 220ms ease;
}

.sheet-plan-card {
  flex: 0 0 auto;
  padding: 14rpx 28rpx 18rpx;
}

.sheet-drag-zone {
  padding-top: 4rpx;
}

.sheet-grabber {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 16rpx;
  border-radius: 999rpx;
  background: rgba(52, 80, 107, 0.26);
}

.sheet-summary-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 28rpx rgba(25, 80, 120, 0.08);
}

.workbench-summary {
  border: 1rpx solid rgba(211, 224, 234, 0.92);
}

.map-mode-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.map-mode-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-mode-meta {
  flex: 0 0 auto;
  color: #657286;
  font-size: 24rpx;
  font-weight: 700;
}

.sheet-summary-main {
  flex: 1;
  min-width: 0;
}

.sheet-title-line,
.control-header,
.list-header,
.lot-main,
.metric-row,
.action-row,
.search-results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sheet-title-line {
  align-items: baseline;
}

.sheet-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.sheet-caret {
  flex: 0 0 auto;
  color: #7a8796;
  font-size: 22rpx;
  font-weight: 700;
}

.sheet-summary {
  display: block;
  margin-top: 10rpx;
  color: #6f7c8d;
  font-size: 24rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.sheet-count-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 0 0 120rpx;
  min-height: 96rpx;
  border-radius: 8rpx;
  color: #2f7fed;
  background: #edf5ff;
}

.sheet-count-number {
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.sheet-count-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.quick-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.workbench-config-row {
  margin-top: 12rpx;
}

.quick-summary-item,
.config-control {
  min-width: 0;
  padding: 16rpx 14rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
}

.is-map-mode:not(.is-sheet-expanded) .bottom-sheet {
  border-radius: 20rpx 20rpx 0 0;
}

.is-map-mode.is-sheet-expanded .map-search-bar {
  display: none;
}

.quick-label,
.quick-value {
  display: block;
}

.quick-label {
  color: #657286;
  font-size: 22rpx;
}

.quick-value {
  margin-top: 8rpx;
  color: #18212f;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-scroll {
  flex: 1;
  min-height: 0;
}

.sheet-content {
  padding: 0 28rpx 36rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 36rpx);
}

.expanded-controls {
  padding-bottom: 18rpx;
}

.map-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #d9e7e3;
  border-radius: 8rpx;
  background: #f2f8f6;
}

.map-meta-main {
  flex: 1;
  min-width: 0;
}

.location-status-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #166a5b;
}

.status-dot.is-locating {
  background: #c25b22;
}

.location-status-text {
  color: #4c6072;
  font-size: 22rpx;
  font-weight: 700;
}

.destination-name,
.destination-address {
  display: block;
}

.destination-name {
  color: #143d35;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.destination-address {
  margin-top: 8rpx;
  color: #5d6f7d;
  font-size: 24rpx;
  line-height: 1.4;
}

.expanded-control-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.primary-control {
  border-color: #cddfeb;
  background: #ffffff;
}

.first-recommendation-preview {
  display: grid;
  grid-template-columns: 52rpx minmax(0, 1fr) 132rpx;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(25, 80, 120, 0.08);
}

.preview-rank {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #166a5b;
  font-size: 24rpx;
  font-weight: 900;
}

.preview-main {
  min-width: 0;
}

.preview-name,
.preview-meta,
.preview-fee,
.preview-note {
  display: block;
}

.preview-name {
  overflow: hidden;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: #657286;
  font-size: 22rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-price {
  text-align: right;
}

.preview-fee {
  color: #c25b22;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.1;
}

.preview-note {
  margin-top: 6rpx;
  color: #657286;
  font-size: 20rpx;
}

.main-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.main-action-button {
  width: 100%;
  min-width: 0;
  min-height: 76rpx;
}

.duration-panel {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-title {
  color: #18212f;
  font-size: 30rpx;
  font-weight: 800;
}

.duration-value {
  color: #166a5b;
  font-size: 36rpx;
  font-weight: 800;
}

.duration-hint {
  display: block;
  margin-top: 8rpx;
  color: #7a8796;
  font-size: 22rpx;
}

.duration-picker-shell {
  position: relative;
  margin-top: 18rpx;
  overflow: hidden;
  border: 1rpx solid #d9e2ea;
  border-radius: 8rpx;
  background: #f8fafc;
}

.duration-picker-shell::before,
.duration-picker-shell::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  z-index: 1;
  height: 84rpx;
  pointer-events: none;
}

.duration-picker-shell::before {
  top: 0;
  background: linear-gradient(180deg, #f8fafc 0%, rgba(248, 250, 252, 0) 100%);
}

.duration-picker-shell::after {
  bottom: 0;
  background: linear-gradient(0deg, #f8fafc 0%, rgba(248, 250, 252, 0) 100%);
}

.duration-picker {
  width: 100%;
  height: 288rpx;
}

.duration-picker-indicator {
  border-top: 1rpx solid #dce4ec;
  border-bottom: 1rpx solid #dce4ec;
  background: rgba(255, 255, 255, 0.72);
}

.duration-picker-mask {
  background: transparent;
}

.duration-wheel-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  color: #8a97a6;
  line-height: 1;
}

.duration-wheel-number {
  min-width: 42rpx;
  color: #18212f;
  font-size: 34rpx;
  font-weight: 800;
  text-align: right;
}

.duration-wheel-unit {
  margin-left: 6rpx;
  color: #58677a;
  font-size: 24rpx;
  font-weight: 700;
}

.custom-panel {
  margin-top: 18rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
  width: 100%;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 82rpx;
  padding: 0 22rpx;
  border: 3rpx solid #111827;
  border-radius: 12rpx;
  background: #ffffff;
  color: #18212f;
  font-size: 30rpx;
}

.clear-button {
  flex: 0 0 104rpx;
  width: 104rpx;
  min-height: 76rpx;
  padding: 0;
  font-size: 26rpx;
}

.choose-button {
  flex: 0 0 128rpx;
  width: 128rpx;
  min-height: 82rpx;
  padding: 0;
  font-size: 24rpx;
  white-space: nowrap;
}

.match-panel,
.search-results-panel {
  margin: -4rpx 0 20rpx;
  padding: 18rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.match-title {
  display: block;
  color: #435268;
  font-size: 24rpx;
  font-weight: 800;
}

.match-row,
.parking-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #eef2f5;
}

.match-row:first-of-type,
.parking-result:first-of-type {
  border-top: 0;
}

.match-info,
.parking-result-main {
  flex: 1;
  min-width: 0;
}

.match-name,
.match-address {
  display: block;
}

.match-name {
  color: #18212f;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.match-address {
  margin-top: 6rpx;
  color: #738196;
  font-size: 23rpx;
  line-height: 1.35;
}

.match-action {
  flex: 0 0 132rpx;
  color: #166a5b;
  font-size: 24rpx;
  font-weight: 800;
  text-align: right;
}

.parking-result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
  color: #3e5065;
  font-size: 23rpx;
}

.parking-result-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  flex: 0 0 112rpx;
  color: #166a5b;
  font-size: 23rpx;
  font-weight: 800;
  text-align: right;
}

.list-header {
  position: relative;
  z-index: 2;
  margin: 4rpx 0 18rpx;
}

.recommendation-sort {
  position: relative;
  flex: 1;
  min-width: 0;
}

.recommendation-sort-trigger {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  min-height: 64rpx;
  color: #e43d30;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.sort-chevron {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(45deg) translateY(-3rpx);
}

.recommendation-sort-trigger.is-open .sort-chevron {
  transform: rotate(225deg) translate(-2rpx, -2rpx);
}

.recommendation-sort-menu {
  position: absolute;
  top: 72rpx;
  left: -28rpx;
  right: -28rpx;
  z-index: 10;
  padding: 18rpx 28rpx 22rpx;
  border-radius: 0 0 28rpx 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 20rpx 42rpx rgba(17, 24, 39, 0.18);
}

.recommendation-sort-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 64rpx;
  color: #5d6878;
  font-size: 30rpx;
  font-weight: 700;
}

.recommendation-sort-option.is-active {
  color: #111827;
  font-weight: 900;
}

.sort-check {
  flex: 0 0 34rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
}

.lot-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.lot-card.is-best {
  border-color: #8dbcf8;
  box-shadow: 0 10rpx 30rpx rgba(47, 127, 237, 0.12);
}

.lot-main {
  align-items: flex-start;
}

.rank-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #1f2937;
  font-size: 26rpx;
  font-weight: 800;
}

.lot-info {
  flex: 1;
  min-width: 0;
}

.lot-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.lot-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.type-label,
.best-label {
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.type-label.is-street {
  color: #ffffff;
  background: #2f7fed;
}

.type-label.is-offstreet {
  color: #ffffff;
  background: #166a5b;
}

.best-label {
  color: #ffffff;
  background: #c25b22;
}

.lot-address {
  display: block;
  margin-top: 8rpx;
  color: #657286;
  font-size: 24rpx;
  line-height: 1.4;
}

.price-box {
  flex: 0 0 128rpx;
  text-align: right;
}

.price,
.price-note {
  display: block;
}

.price {
  color: #c25b22;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.price-note {
  margin-top: 8rpx;
  color: #657286;
  font-size: 22rpx;
}

.metric-row {
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 20rpx;
  color: #3e5065;
  font-size: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.reason {
  display: block;
  margin-top: 18rpx;
  color: #2c3e50;
  font-size: 26rpx;
  line-height: 1.5;
}

.source-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.source-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  overflow: hidden;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.source-avatar-image {
  width: 100%;
  height: 100%;
}

.source-name,
.source-confidence {
  color: #657286;
  font-size: 22rpx;
  line-height: 1.35;
}

.source-name {
  color: #344456;
  font-weight: 700;
}

.action-row {
  margin-top: 22rpx;
}

.action-button {
  flex: 1;
}

.sheet-empty {
