.index-page {
  padding-bottom: 48rpx;
}

.top-panel {
  padding: 28rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.title-row,
.control-header,
.list-header,
.lot-main,
.metric-row,
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.title-row {
  align-items: flex-start;
}

.title-row > view {
  flex: 1;
  min-width: 0;
}

.title-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex: 0 0 210rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: #5d6f7d;
  font-size: 24rpx;
}

.page-title {
  display: block;
  color: #111827;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.add-button {
  width: 192rpx;
  flex: 0 0 auto;
  min-width: 0;
  max-width: 220rpx;
  min-height: 68rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
}

.account-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 192rpx;
  min-height: 52rpx;
  padding: 0 12rpx;
  border: 1rpx solid #d8e3ea;
  border-radius: 999rpx;
  background: #f8fafc;
}

.account-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #9aa6b2;
}

.account-chip.is-authenticated .account-dot {
  background: #166a5b;
}

.account-status,
.account-action {
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.account-status {
  color: #243244;
  font-weight: 700;
}

.account-action {
  color: #657286;
}

.destination-panel {
  display: block;
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #d9e7e3;
  border-radius: 8rpx;
  background: #f2f8f6;
}

.destination-name,
.destination-address {
  display: block;
}

.destination-name {
  color: #143d35;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.destination-address {
  margin-top: 8rpx;
  color: #5d6f7d;
  font-size: 24rpx;
  line-height: 1.4;
}

.destination-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  margin-top: 20rpx;
}

.destination-button {
  width: 100%;
  min-width: 0;
  min-height: 64rpx;
  padding: 0 10rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.vehicle-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #dde7ef;
  border-radius: 8rpx;
  background: #f8fafc;
}

.vehicle-panel > view {
  flex: 1;
  min-width: 0;
}

.vehicle-label,
.vehicle-value,
.vehicle-hint {
  display: block;
}

.vehicle-label {
  color: #657286;
  font-size: 22rpx;
}

.vehicle-value {
  margin-top: 6rpx;
  color: #18212f;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.vehicle-hint {
  margin-top: 6rpx;
  color: #738196;
  font-size: 22rpx;
  line-height: 1.35;
}

.vehicle-action {
  flex: 0 0 72rpx;
  color: #166a5b;
  font-size: 24rpx;
  font-weight: 800;
  text-align: right;
}

.duration-panel {
  margin-top: 32rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #e7edf2;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 28rpx;
  width: 100%;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d9e2ea;
  border-radius: 6rpx;
  background: #f8fafc;
  color: #18212f;
  font-size: 28rpx;
}

.clear-button {
  flex: 0 0 104rpx;
  width: 104rpx;
  min-height: 76rpx;
  padding: 0;
  font-size: 26rpx;
}

.choose-button {
  flex: 0 0 154rpx;
  width: 154rpx;
  min-height: 76rpx;
  padding: 0;
  font-size: 24rpx;
  white-space: nowrap;
}

.match-panel,
.search-results-panel {
  margin: -12rpx 0 28rpx;
  padding: 18rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.match-title {
  display: block;
  color: #435268;
  font-size: 24rpx;
  font-weight: 800;
}

.match-row,
.parking-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #eef2f5;
}

.match-row:first-of-type,
.parking-result:first-of-type {
  border-top: 0;
}

.match-info,
.parking-result-main {
  flex: 1;
  min-width: 0;
}

.match-name,
.match-address {
  display: block;
}

.match-name {
  color: #18212f;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.match-address {
  margin-top: 6rpx;
  color: #738196;
  font-size: 23rpx;
  line-height: 1.35;
}

.match-action {
  flex: 0 0 132rpx;
  color: #166a5b;
  font-size: 24rpx;
  font-weight: 800;
  text-align: right;
}

.search-results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 4rpx;
}

.parking-result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
  color: #3e5065;
  font-size: 23rpx;
}

.parking-result-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  flex: 0 0 112rpx;
  color: #166a5b;
  font-size: 23rpx;
  font-weight: 800;
  text-align: right;
}

.source-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.source-line.compact {
  margin-top: 10rpx;
}

.source-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  overflow: hidden;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.source-avatar-image {
  width: 100%;
  height: 100%;
}

.source-name,
.source-confidence {
  color: #657286;
  font-size: 22rpx;
  line-height: 1.35;
}

.source-name {
  color: #344456;
  font-weight: 700;
}

.section-title {
  color: #18212f;
  font-size: 30rpx;
  font-weight: 700;
}

.duration-value {
  color: #166a5b;
  font-size: 36rpx;
  font-weight: 800;
}

.duration-hint {
  display: block;
  margin-top: 8rpx;
  color: #7a8796;
  font-size: 22rpx;
}

.quick-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
  width: 100%;
}

.quick-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 68rpx;
  border-radius: 6rpx;
  color: #34506b;
  background: #edf3f6;
  font-size: 26rpx;
  font-weight: 600;
}

.quick-chip-text {
  display: block;
  max-width: 100%;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quick-chip.is-active {
  color: #ffffff;
  background: #166a5b;
}

.map-preview {
  width: 100%;
  height: 360rpx;
  margin-top: 24rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.summary-box {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-left: 8rpx solid #166a5b;
  border-radius: 8rpx;
  background: #eef8f5;
  color: #23413b;
  font-size: 28rpx;
  line-height: 1.55;
}

.list-header {
  margin: 34rpx 0 18rpx;
}

.lot-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #dce4ec;
  border-radius: 8rpx;
  background: #ffffff;
}

.lot-card.is-best {
  border-color: #89c8b9;
  box-shadow: 0 10rpx 30rpx rgba(22, 106, 91, 0.08);
}

.lot-main {
  align-items: flex-start;
}

.rank-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #1f2937;
  font-size: 26rpx;
  font-weight: 800;
}

.lot-info {
  flex: 1;
  min-width: 0;
}

.lot-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.lot-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.best-label {
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  color: #ffffff;
  background: #c25b22;
  font-size: 20rpx;
  font-weight: 700;
}

.lot-address {
  display: block;
  margin-top: 8rpx;
  color: #657286;
  font-size: 24rpx;
  line-height: 1.4;
}

.price-box {
  flex: 0 0 128rpx;
  text-align: right;
}

.price,
.price-note {
  display: block;
}

.price {
  color: #c25b22;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.price-note {
  margin-top: 8rpx;
  color: #657286;
  font-size: 22rpx;
}

.metric-row {
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 20rpx;
  color: #3e5065;
  font-size: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.reason {
  display: block;
  margin-top: 18rpx;
  color: #2c3e50;
  font-size: 26rpx;
  line-height: 1.5;
}

.action-row {
  margin-top: 22rpx;
}

.action-button {
  flex: 1;
}
