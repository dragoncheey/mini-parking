<view class="page index-page {{mapExpanded ? 'is-map-mode' : ''}} {{sheetExpanded ? 'is-sheet-expanded' : ''}}">
  <map
    class="map-background"
    style="height: {{mapViewportHeightPx}}px;"
    latitude="{{mapLatitude}}"
    longitude="{{mapLongitude}}"
    scale="{{mapScale}}"
    markers="{{mapMarkers}}"
    include-points="{{mapPoints}}"
    show-location="{{hasLocation}}"
    enable-scroll="{{mapGestureEnabled}}"
    bindmarkertap="onMarkerTap"
  ></map>

  <view wx:if="{{!mapExpanded}}" class="map-top-actions">
    <view class="map-account-chip {{accountStatusClass}}" bindtap="login">
      <text class="account-dot"></text>
      <text class="account-status">{{accountStatusText}}</text>
      <text class="account-action">{{accountActionText}}</text>
    </view>
    <button
      class="map-add-action"
      bindtap="goAdd"
      aria-label="分享停车场"
    >
      <text class="map-add-plus">+</text>
    </button>
  </view>

  <view wx:if="{{mapExpanded}}" class="map-search-bar">
    <view class="map-back-button" bindtap="exitMapMode">‹</view>
    <view class="search-shell">
      <text class="search-prefix">⌕</text>
      <input
        class="map-search-input"
        value="{{searchKeyword}}"
        bindfocus="expandSheetFromSearch"
        bindinput="onSearchInput"
        confirm-type="search"
        placeholder="搜索目的地"
      />
      <view wx:if="{{searchKeyword}}" class="map-more-button" bindtap="clearSearch">×</view>
    </view>
  </view>

  <view class="map-action-stack" style="bottom: {{mapLocateBottomPx}}px;">
    <view
      wx:if="{{!mapExpanded}}"
      class="map-round-button expand-map-control"
      bindtap="enterMapMode"
      aria-role="button"
      aria-label="放大地图"
    >
      <text class="expand-corner expand-corner-tl"></text>
      <text class="expand-corner expand-corner-tr"></text>
      <text class="expand-corner expand-corner-bl"></text>
      <text class="expand-corner expand-corner-br"></text>
    </view>
    <view
      class="map-round-button locate-control"
      bindtap="useCurrentLocationAsDestination"
      hover-class="locate-control-hover"
      aria-role="button"
      aria-label="定位到当前位置"
    >
      <view class="locate-orb">
        <view class="locate-ring locate-ring-outer"></view>
        <view class="locate-ring locate-ring-inner"></view>
        <view class="locate-axis locate-axis-x"></view>
        <view class="locate-axis locate-axis-y"></view>
        <view class="locate-arrow"></view>
        <view class="locate-dot"></view>
      </view>
    </view>
  </view>

  <view
    class="bottom-sheet {{sheetExpanded ? 'is-expanded' : 'is-collapsed'}} {{sheetAnimating ? 'is-animating' : ''}}"
    style="height: {{sheetHeightPx}}px; transform: translateY({{sheetTranslateY}}px);"
    bindtouchstart="onSheetInteractionStart"
    bindtouchend="onSheetInteractionEnd"
    bindtouchcancel="onSheetInteractionEnd"
  >
    <view class="sheet-plan-card">
      <view
        class="sheet-drag-zone"
        bindtap="toggleSheet"
        catchtouchstart="onSheetTouchStart"
        catchtouchmove="onSheetTouchMove"
        catchtouchend="onSheetTouchEnd"
        catchtouchcancel="onSheetTouchCancel"
      >
        <view class="sheet-grabber"></view>
        <view wx:if="{{!mapExpanded}}" class="workbench-summary sheet-summary-row">
          <view class="sheet-summary-main">
            <view class="sheet-title-line">
              <text class="sheet-title">{{destinationName}}</text>
              <text class="sheet-caret">{{sheetExpanded ? '下拉收起' : '上拉查看'}}</text>
            </view>
            <text class="sheet-summary">{{summary}}</text>
          </view>
          <view class="sheet-count-box">
            <text class="sheet-count-number">{{recommendations.length}}</text>
            <text class="sheet-count-label">个停车场</text>
          </view>
        </view>
        <view wx:if="{{!sheetExpanded && !mapExpanded}}" class="workbench-config-row quick-summary-grid">
          <view class="quick-summary-item" bindtap="chooseDestination">
            <text class="quick-label">目的地</text>
            <text class="quick-value">{{destinationName}}</text>
          </view>
          <view class="quick-summary-item" bindtap="toggleDurationPicker">
            <text class="quick-label">时长</text>
            <text class="quick-value">{{durationText}}</text>
          </view>
          <view class="quick-summary-item" bindtap="goVehicles">
            <text class="quick-label">车辆</text>
            <text class="quick-value">{{currentVehicleText}}</text>
          </view>
        </view>
        <block wx:if="{{!sheetExpanded && !mapExpanded && hasRecommendations}}">
          <view
            wx:for="{{recommendations}}"
            wx:key="id"
            wx:if="{{index === 0}}"
            class="first-recommendation-preview"
            data-id="{{item.id}}"
            catchtap="goDetail"
          >
            <view class="preview-rank">{{item.rank}}</view>
            <view class="preview-main">
              <text class="preview-name">{{item.name}}</text>
              <text class="preview-meta">{{item.distanceText}} · 步行约 {{item.walkingMinutes}} 分钟 · {{item.availabilityText}}</text>
            </view>
            <view class="preview-price">
              <text class="preview-fee">{{item.feeText}}</text>
              <text class="preview-note">{{item.durationText}}</text>
            </view>
          </view>
        </block>
        <view wx:if="{{mapExpanded && !sheetExpanded}}" class="map-mode-summary">
          <text class="map-mode-title">{{destinationName}}</text>
          <text class="map-mode-meta">{{recommendations.length}} 个停车场 · {{durationText}}</text>
        </view>
      </view>
    </view>

    <scroll-view
      class="sheet-scroll"
      scroll-y="{{sheetExpanded}}"
    >
      <view class="sheet-content">
        <view wx:if="{{sheetExpanded}}" class="expanded-controls">
          <view class="expanded-control-row">
            <view class="config-control primary-control" bindtap="chooseDestination">
              <text class="quick-label">目的地</text>
              <text class="quick-value">{{destinationName}}</text>
            </view>
            <view class="config-control primary-control" bindtap="toggleDurationPicker">
              <text class="quick-label">时长</text>
              <text class="quick-value">{{durationText}}</text>
            </view>
            <view class="config-control" bindtap="goVehicles">
              <text class="quick-label">车辆</text>
              <text class="quick-value">{{currentVehicleText}}</text>
            </view>
          </view>

          <view wx:if="{{showDurationPicker}}" class="duration-panel">
            <view class="control-header">
              <text class="section-title">预计停车</text>
              <text class="duration-value">{{durationText}}</text>
            </view>
            <text class="duration-hint">默认 30 分钟，1 分钟一档</text>
            <view class="duration-picker-shell">
              <picker-view
                class="duration-picker"
                indicator-class="duration-picker-indicator"
                indicator-style="height: 72rpx;"
                mask-class="duration-picker-mask"
                value="{{durationPickerValue}}"
                bindchange="onDurationPickerChange"
              >
                <picker-view-column>
                  <view
                    wx:for="{{durationDayOptions}}"
                    wx:key="value"
                    class="duration-wheel-item"
                  >
                    <text class="duration-wheel-number">{{item.label}}</text>
                    <text class="duration-wheel-unit">{{item.unit}}</text>
                  </view>
                </picker-view-column>
                <picker-view-column>
                  <view
                    wx:for="{{durationHourOptions}}"
                    wx:key="value"
                    class="duration-wheel-item"
                  >
                    <text class="duration-wheel-number">{{item.label}}</text>
                    <text class="duration-wheel-unit">{{item.unit}}</text>
                  </view>
                </picker-view-column>
                <picker-view-column>
                  <view
                    wx:for="{{durationMinuteOptions}}"
                    wx:key="value"
                    class="duration-wheel-item"
                  >
                    <text class="duration-wheel-number">{{item.label}}</text>
                    <text class="duration-wheel-unit">{{item.unit}}</text>
                  </view>
                </picker-view-column>
              </picker-view>
            </view>
          </view>

          <view class="custom-panel">
            <view class="search-row">
              <input
                class="search-input"
                value="{{searchKeyword}}"
                bindinput="onDestinationInput"
                confirm-type="search"
                placeholder="搜索目的地"
              />
              <button class="secondary-button choose-button" bindtap="searchDestinationCandidates">匹配</button>
            </view>

            <view wx:if="{{hasDestinationMatches}}" class="match-panel">
              <text class="match-title">目的地候选</text>
              <view
                wx:for="{{destinationMatches}}"
                wx:key="id"
                class="match-row"
                data-id="{{item.id}}"
                bindtap="selectDestinationMatch"
              >
                <view class="match-info">
                  <text class="match-name">{{item.name}}</text>
                  <text class="match-address">{{item.address}}</text>
                </view>
                <text class="match-action">设为目的地</text>
              </view>
            </view>

          </view>
        </view>

        <view class="list-header">
          <text class="section-title">附近停车场</text>
          <text class="muted">{{recommendations.length}} 个停车场</text>
        </view>

        <block wx:if="{{hasRecommendations}}">
          <view
            wx:for="{{recommendations}}"
            wx:key="id"
            class="lot-card {{item.bestClass}}"
          >
            <view class="lot-main">
              <view class="rank-badge">{{item.rank}}</view>
              <view class="lot-info">
                <view class="lot-title-line">
                  <text class="lot-name">{{item.name}}</text>
                  <text class="type-label {{item.parkingTypeClass}}">{{item.parkingTypeText}}</text>
                  <text wx:if="{{item.isBest}}" class="best-label">推荐</text>
                </view>
                <text class="lot-address">{{item.address}}</text>
              </view>
              <view class="price-box">
                <text class="price">{{item.feeText}}</text>
                <text class="price-note">{{item.durationText}}</text>
              </view>
            </view>

            <view class="metric-row">
              <text>距目的地 {{item.distanceText}}</text>
              <text>步行约 {{item.walkingMinutes}} 分钟</text>
              <text>{{item.availabilityText}}</text>
            </view>

            <view class="tag-row">
              <text
                wx:for="{{item.tags}}"
                wx:key="*this"
                class="pill"
              >{{item}}</text>
            </view>

            <text class="reason">{{item.reason}}</text>

            <view class="source-line">
              <view class="source-avatar" style="background: {{item.owner.avatarColor}}">
                <image wx:if="{{item.owner.avatarUrl}}" class="source-avatar-image" src="{{item.owner.avatarUrl}}" mode="aspectFill" />
                <text wx:else>{{item.owner.avatarText}}</text>
              </view>
              <text class="source-name">{{item.owner.nickname}}</text>
              <text class="source-confidence">可信度 {{item.confidence}}</text>
              <text wx:if="{{item.voteStats.total}}" class="source-confidence">赞 {{item.voteStats.up}} / 踩 {{item.voteStats.down}}</text>
            </view>

            <view class="action-row">
              <button class="primary-button action-button" data-id="{{item.id}}" bindtap="openNavigation">导航</button>
              <button class="ghost-button action-button" data-id="{{item.id}}" bindtap="goDetail">详情</button>
            </view>
          </view>
        </block>

        <view wx:else class="empty sheet-empty">
          {{emptyText}}
        </view>
      </view>
    </scroll-view>
  </view>
</view>
