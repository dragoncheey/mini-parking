<view class="page vehicles-page">
  <view class="vehicles-header">
    <view>
      <text class="vehicles-kicker">车辆配置</text>
      <text class="vehicles-title">{{pageTitle}}</text>
    </view>
    <button wx:if="{{!loginRequired}}" class="secondary-button add-entry-button" bindtap="openAddPanel">添加</button>
  </view>

  <view wx:if="{{loginRequired}}" class="login-panel">
    <text class="login-title">登录后管理车辆</text>
    <text class="login-copy">车辆只保存在当前用户下，用于区分新能源和燃油车计费。</text>
    <button class="primary-button login-button" bindtap="login">登录</button>
  </view>

  <block wx:else>
    <view class="current-card">
      <view class="current-card-top">
        <view>
          <text class="current-label">当前车辆</text>
          <text class="current-value">{{currentVehicleLabel}}</text>
        </view>
        <button class="ghost-button add-entry-button" bindtap="openAddPanel">更换</button>
      </view>
      <text class="current-copy">推荐价格会按当前车型匹配基础规则或新能源优惠。</text>
    </view>

    <view class="list-section">
      <view wx:if="{{vehicles.length}}">
        <view
          wx:for="{{vehicles}}"
          wx:key="id"
          class="vehicle-card {{item.id === currentVehicleId ? 'is-current' : ''}} {{item.energyClass}}"
          data-id="{{item.id}}"
          bindtap="openEditPanel"
        >
          <view class="vehicle-card-main">
            <view class="vehicle-card-head">
              <text class="plate-number">{{item.plateDisplay}}</text>
              <text wx:if="{{item.id === currentVehicleId}}" class="current-badge">当前</text>
            </view>
            <view class="vehicle-card-body">
              <text class="energy-badge">{{item.vehicleTypeLabel}}</text>
            </view>
          </view>
          <view class="vehicle-actions">
            <button class="secondary-button small-button" data-id="{{item.id}}" catchtap="useVehicle">设当前</button>
            <button class="ghost-button small-button" data-id="{{item.id}}" catchtap="removeVehicle">删除</button>
          </view>
        </view>
      </view>
      <view wx:else class="empty">{{emptyText}}</view>
    </view>
  </block>

  <view wx:if="{{showAddPanel}}" class="plate-overlay" bindtap="closeAddPanel">
    <view class="plate-sheet" catchtap="stopPanelTap">
      <text class="sheet-title">{{panelTitle}}</text>

      <view class="plate-preview-card">
        <view class="plate-slots">
          <view
            wx:for="{{form.plateSlots}}"
            wx:key="index"
            class="plate-slot {{item.filled ? 'is-filled' : ''}} {{item.active ? 'is-active' : ''}} {{index === 7 ? 'is-energy-slot' : ''}}"
            data-index="{{index}}"
            bindtap="setPlateFocus"
          >
            <text>{{item.value}}</text>
          </view>
        </view>
        <view class="plate-benefit-row">
          <text class="benefit-icon">✓</text>
          <text>绑定车牌号可识别车型专属优惠</text>
        </view>
        <view class="auto-type-row">
          <text>已识别</text>
          <text class="auto-type-value">{{form.vehicleTypeLabel}}</text>
        </view>
      </view>

      <view class="keyboard-panel">
        <block wx:if="{{form.keyboardMode === 'province'}}">
          <view
            wx:for="{{provinceKeys}}"
            wx:for-item="row"
            wx:key="*this"
            class="keyboard-row"
          >
            <view
              wx:for="{{row}}"
              wx:for-item="key"
              wx:key="*this"
              class="keyboard-key"
              data-key="{{key}}"
              bindtap="onPlateKeyTap"
            >{{key}}</view>
          </view>
        </block>
        <block wx:else>
          <view
            wx:if="{{form.activePlateIndex === 1}}"
            wx:for="{{firstLetterKeys}}"
            wx:for-item="row"
            wx:key="*this"
            class="keyboard-row"
          >
            <view
              wx:for="{{row}}"
              wx:for-item="key"
              wx:key="*this"
              class="keyboard-key"
              data-key="{{key}}"
              bindtap="onPlateKeyTap"
            >{{key}}</view>
          </view>
          <view
            wx:if="{{form.activePlateIndex !== 1}}"
            wx:for="{{letterKeys}}"
            wx:for-item="row"
            wx:key="*this"
            class="keyboard-row"
          >
            <view
              wx:for="{{row}}"
              wx:for-item="key"
              wx:key="*this"
              class="keyboard-key {{key === '删除' ? 'is-delete' : ''}}"
              data-key="{{key}}"
              bindtap="onPlateKeyTap"
            >{{key}}</view>
          </view>
          <view wx:if="{{form.activePlateIndex === 1}}" class="keyboard-row">
            <view class="keyboard-key is-delete" data-key="删除" bindtap="onPlateKeyTap">删除</view>
          </view>
        </block>
      </view>

      <button class="confirm-button" loading="{{loading}}" bindtap="saveVehicle">{{confirmButtonText}}</button>
    </view>
  </view>
</view>
